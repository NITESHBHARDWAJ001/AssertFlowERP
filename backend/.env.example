# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/assetflow?schema=public"

NODE_ENV=development
PORT=4000

# JWT secrets - generate strong random values for real environments
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7

# Frontend origin(s) allowed to call this API (comma-separated)
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:4000

# Cloudinary (leave blank in dev to fall back to local disk storage under /uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (leave blank in dev to log emails to the console instead of sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="AssetFlow <no-reply@assetflow.local>"

# Seed script: creates the one platform Super Admin
SUPER_ADMIN_EMAIL=superadmin@assetflow.local
SUPER_ADMIN_PASSWORD=ChangeMe123!

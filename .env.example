# Used only by docker-compose.yml for local verification of the backend's
# Docker image. Copy to .env (same directory as docker-compose.yml) - Docker
# Compose loads it automatically. Not used by the frontend or backend dev
# servers directly (each has its own .env under frontend/ and backend/).

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
SUPER_ADMIN_EMAIL=superadmin@assetflow.local
SUPER_ADMIN_PASSWORD=ChangeMe123!

# Optional - leave blank to use local-disk upload fallback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
